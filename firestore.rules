rules_version = '2';

service cloud.firestore {
  match /databases/{database}/documents {
    
    // Helper: Is the user logged in?
    function isSignedIn() {
      return request.auth != null;
    }

    // Helper: Does the user own this document?
    function isOwner(userId) {
      return request.auth.uid == userId;
    }

    // 1. Users Collection
    match /users/{userId} {
      allow read: if isSignedIn();
      allow write: if isSignedIn() && isOwner(userId);
    }

    // 2. Jobs Collection
    match /jobs/{jobId} {
      allow read: if true;
      allow write: if isSignedIn();
    }

    // 3. Applications Collection
    match /applications/{appId} {
      allow read, write: if isSignedIn() && 
        (request.auth.uid == resource.data.userId || request.auth.uid == resource.data.companyId);
      allow create: if isSignedIn() && request.resource.data.userId == request.auth.uid;
    }

    // 4. Notifications
    match /notifications/{notifId} {
      allow read, write: if isSignedIn() && request.auth.uid == resource.data.recipientId;
      allow create: if isSignedIn();
    }

    // 5. App Configuration (The "Vault")
    match /config/openai {
      // Only logged-in users can read the key (for resume generation)
      allow read: if isSignedIn();
      // SECURITY: No one can ever write to this from the app
      allow write: if false;
    }
  }
}
